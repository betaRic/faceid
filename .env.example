# Firebase (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (Server)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Session & Auth
# Session duration: 30 days (auto-refreshes when < 7 days remaining)
ADMIN_SESSION_SECRET=
ADMIN_REGIONAL_PIN=
ADMIN_ALLOWED_EMAILS=

# Security
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
CRON_SECRET=

# Cron endpoints:
# POST /api/cron/rebuild-daily-summary - Rebuilds daily attendance summaries
# GET  /api/cron/warm-biometric-cache - Pre-warms biometric index KV cache

# Vercel KV (required for session caching & rate limiting)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Optional
NEXT_PUBLIC_ALLOW_LOCAL_BIOMETRIC_FALLBACK=false
