# Firebase (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (Server)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Session & Auth
# Session duration: 8 hours (auto-refreshes when < 2 hours remaining)
ADMIN_SESSION_SECRET=
ADMIN_REGIONAL_PIN=
ADMIN_ALLOWED_EMAILS=

# HR Session & Auth
HR_SESSION_SECRET=
HR_PIN_SALT=
HR_ALLOWED_EMAILS=

# Security
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
CRON_SECRET=

# Cron endpoints:
# POST /api/cron/rebuild-daily-summary - Rebuilds daily attendance summaries
# GET  /api/cron/warm-biometric-cache - Pre-warms biometric index KV cache

# Vercel KV (required for session caching & rate limiting)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Optional
NEXT_PUBLIC_ALLOW_LOCAL_BIOMETRIC_FALLBACK=false

# Model hosting
# Set to true and place model files in /public/models/human to serve locally.
# Defaults to false (models loaded from jsDelivr CDN).
# Do not set true on Railway/Vercel unless a real CDN/proxy is in front of it.
NEXT_PUBLIC_USE_LOCAL_MODELS=false
# Optional explicit Human model host. Example:
# NEXT_PUBLIC_HUMAN_MODEL_URL=https://cdn.jsdelivr.net/npm/@vladmandic/human@3.3.6/models
NEXT_PUBLIC_HUMAN_MODEL_URL=

# Server attendance speed/security tradeoff
# Default false keeps server attendance embedding to detector + FaceRes only.
# Browser burst liveness remains required. Set true only after benchmarking.
SERVER_ATTENDANCE_PAD_ENABLED=false

# Redis (alternative to Vercel KV for rate limiting)
# Only required if not using Vercel KV. When both are set, KV takes priority.
# For Railway asia-southeast1, use an Asia/Singapore Redis endpoint.
# A US-East Redis endpoint can add seconds to attendance requests.
REDIS_URL=
# Change this when you need a fresh Redis namespace but cannot delete the free database.
# Example: faceattend-railway-2026-04-28
CACHE_KEY_PREFIX=

# Temporary Railway/OpenVINO bridge
# Required only while testing OpenVINO on Railway or NAS.
OPENVINO_BENCHMARK_SECRET=
OPENVINO_BENCHMARK_RETURN_DESCRIPTOR=false
INCLUDE_OPENVINO_RUNTIME=false
